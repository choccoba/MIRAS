    "# ── Concordance Analysis ──────────────────────────────────────────────────────\n",
    "def compute_concordance(df, group_by='mirna'):\n",
    "    \"\"\"\n",
    "    For each miRNA: \n",
    "    - Count studies reporting up vs down\n",
    "    - Compute concordance ratio\n",
    "    - Flag IT-specific studies\n",
    "    - Identify discordant tissue vs serum findings\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    \n",
    "    for mirna, group in df.groupby(group_by):\n",
    "        n_up     = sum(group['direction'] == +1)\n",
    "        n_down   = sum(group['direction'] == -1)\n",
    "        n_total  = len(group)\n",
    "        n_wt     = sum(group['n'])  # weighted by sample size\n",
    "        \n",
    "        # Concordance: 1.0 = all same direction, 0.0 = equal split\n",
    "        concordance = abs(n_up - n_down) / n_total if n_total > 0 else 0\n",
    "        dominant_dir = 'up' if n_up > n_down else 'down' if n_down > n_up else 'discordant'\n",
    "        \n",
    "        # Tissue-serum discordance flag (biologically important!)\n",
    "        tissue_dirs = group[group['sample'].str.contains('liver', na=False)]['direction'].tolist()\n",
    "        serum_dirs  = group[group['sample'].str.contains('serum|plasma', na=False)]['direction'].tolist()\n",
    "        tissue_serum_discordant = (len(tissue_dirs) > 0 and len(serum_dirs) > 0 and\n",
    "                                    tissue_dirs[0] != serum_dirs[0])\n",
    "        \n",
    "        # IT-phase specific evidence\n",
    "        it_studies = group[group['disease_phase'].str.contains('IT', na=False)]\n",
    "        has_IT_evidence = len(it_studies) > 0\n",
    "        \n",
    "        # Target gene list\n",
    "        all_targets = set()\n",
    "        for targets in group['target_genes'].dropna():\n",
    "            all_targets.update(targets.split(','))\n",
    "        \n",
    "        # v18 anchor coverage\n",
    "        v18_anchors = ['AIM2','LGALS9','TGFB1','DNMT1','SOCS1','FOXP3',\n",
    "                       'IL10','PDCD1','CD274','CTLA4']\n",
    "        v18_hit = [g for g in all_targets if g.strip() in v18_anchors]\n",
    "        \n",
    "        results.append({\n",
    "            'mirna':                    mirna,\n",
    "            'n_studies':                n_total,\n",
    "            'n_up':                     n_up,\n",
    "            'n_down':                   n_down,\n",
    "            'weighted_N':               n_wt,\n",
    "            'concordance':              round(concordance, 3),\n",
    "            'dominant_direction':       dominant_dir,\n",
    "            'tissue_serum_discordant':  tissue_serum_discordant,\n",
    "            'has_IT_evidence':          has_IT_evidence,\n",
    "            'v18_anchor_targets':       '; '.join(v18_hit),\n",
    "            'n_v18_anchors':            len(v18_hit),\n",
    "            'all_targets':              '; '.join(sorted(all_targets))\n",
    "        })\n",
    "    \n",
    "    result_df = pd.DataFrame(results).sort_values(\n",
    "        ['n_v18_anchors', 'has_IT_evidence', 'concordance'],\n",
    "        ascending=[False, False, False]\n",
    "    )\n",
    "    return result_df\n",
    "\n",
    "concordance_df = compute_concordance(df)\n",
    "print('\\n=== Concordance Analysis Results ===')\n",
    "print(concordance_df[['mirna','n_studies','dominant_direction','concordance',\n",
    "                        'has_IT_evidence','n_v18_anchors','v18_anchor_targets']].to_string(index=False))"
   ],
   "metadata": {},
   "outputs": []
