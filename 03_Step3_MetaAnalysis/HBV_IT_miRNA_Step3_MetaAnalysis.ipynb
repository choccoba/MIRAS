  {
   "cell_type": "code",
   "source": [
    "# ── Priority Tier Assignment ──────────────────────────────────────────────────\n",
    "def assign_priority_tier(row):\n",
    "    \"\"\"\n",
    "    Tier 1: IT evidence + v18 anchor target + high concordance\n",
    "    Tier 2: v18 anchor target + concordant  \n",
    "    Tier 3: IT evidence only OR concordant HBV\n",
    "    Tier 4: HBV-associated, low concordance\n",
    "    \"\"\"\n",
    "    if row['has_IT_evidence'] and row['n_v18_anchors'] > 0 and row['concordance'] >= 0.8:\n",
    "        return 'Tier1_IT_v18_concordant'\n",
    "    elif row['n_v18_anchors'] > 0 and row['concordance'] >= 0.6:\n",
    "        return 'Tier2_v18_concordant'\n",
    "    elif row['has_IT_evidence'] or row['concordance'] >= 0.8:\n",
    "        return 'Tier3_IT_or_concordant'\n",
    "    else:\n",
    "        return 'Tier4_HBV_general'\n",
    "\n",
    "concordance_df['priority_tier'] = concordance_df.apply(assign_priority_tier, axis=1)\n",
    "\n",
    "print('\\nPriority tier distribution:')\n",
    "print(concordance_df['priority_tier'].value_counts())\n",
    "\n",
    "print('\\nTier 1 miRNAs (IT + v18 + concordant):')\n",
    "t1 = concordance_df[concordance_df['priority_tier'] == 'Tier1_IT_v18_concordant']\n",
    "if len(t1) > 0:\n",
    "    print(t1[['mirna','dominant_direction','v18_anchor_targets','concordance']].to_string(index=False))\n",
    "else:\n",
    "    print('  None with current literature data — expand PubMed search')\n",
    "\n",
    "print('\\nTier 2 miRNAs (v18 anchor targets, concordant):')\n",
    "t2 = concordance_df[concordance_df['priority_tier'] == 'Tier2_v18_concordant']\n",
    "print(t2[['mirna','dominant_direction','v18_anchor_targets','concordance']].to_string(index=False))"
   ],
