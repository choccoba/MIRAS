    "# ── Visualization: Concordance Heatmap ────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 8))\n",
    "\n",
    "# Plot 1: Concordance bubble chart\n",
    "ax1 = axes[0]\n",
    "colors = {'Tier1_IT_v18_concordant': '#D85A30',\n",
    "           'Tier2_v18_concordant':    '#7F77DD',\n",
    "           'Tier3_IT_or_concordant':  '#1D9E75',\n",
    "           'Tier4_HBV_general':       '#888780'}\n",
    "\n",
    "for _, row in concordance_df.iterrows():\n",
    "    color = colors.get(row['priority_tier'], '#888780')\n",
    "    size  = max(50, row['weighted_N'] / 5)\n",
    "    ax1.scatter(row['n_v18_anchors'], row['concordance'],\n",
    "                s=size, color=color, alpha=0.7,\n",
    "                marker='*' if row['has_IT_evidence'] else 'o')\n",
    "    ax1.annotate(row['mirna'].replace('hsa-',''),\n",
    "                 (row['n_v18_anchors'], row['concordance']),\n",
    "                 fontsize=8, ha='left', va='bottom')\n",
    "\n",
    "ax1.set_xlabel('Number of v18 anchor genes targeted', fontsize=10)\n",
    "ax1.set_ylabel('Concordance across studies', fontsize=10)\n",
    "ax1.set_title('miRNA priority: v18 anchor coverage vs concordance\\n(★ = has IT-phase evidence)', fontsize=10)\n",
    "ax1.axhline(0.8, color='gray', linestyle='--', alpha=0.5, label='Concordance threshold')\n",
    "ax1.set_ylim(0, 1.1)\n",
    "\n",
    "# Legend\n",
    "from matplotlib.patches import Patch\n",
    "legend_elements = [Patch(facecolor=v, label=k.replace('_', ' '))\n",
    "                   for k, v in colors.items()]\n",
    "ax1.legend(handles=legend_elements, fontsize=8, loc='upper left')\n",
    "\n",
    "# Plot 2: v18 anchor coverage matrix\n",
    "ax2 = axes[1]\n",
    "v18_anchors = ['AIM2','LGALS9','TGFB1','DNMT1','SOCS1','FOXP3','IL10','PDCD1','CD274','CTLA4']\n",
    "mirna_list  = concordance_df['mirna'].tolist()\n",
    "\n",
    "# Build binary matrix: miRNA × v18_anchor_gene\n",
    "matrix = pd.DataFrame(0, index=mirna_list, columns=v18_anchors)\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    if pd.notna(row.get('target_genes')):\n",
    "        targets = [t.strip() for t in row['target_genes'].split(',')]\n",
    "        for gene in targets:\n",
    "            if gene in v18_anchors and row['mirna'] in matrix.index:\n",
    "                matrix.loc[row['mirna'], gene] = 1\n",
    "\n",
    "# Only show rows with at least one hit\n",
    "matrix_filt = matrix[matrix.sum(axis=1) > 0]\n",
    "if len(matrix_filt) > 0:\n",
    "    sns.heatmap(matrix_filt, cmap='Blues', cbar=False, ax=ax2,\n",
    "                linewidths=0.5, linecolor='gray')\n",
    "    ax2.set_title('miRNA → v18 anchor gene coverage\\n(blue = known target)', fontsize=10)\n",
    "    ax2.set_xticklabels(ax2.get_xticklabels(), rotation=45, ha='right', fontsize=9)\n",
    "    ax2.set_yticklabels([y.replace('hsa-','') for y in matrix_filt.index],\n",
    "                         rotation=0, fontsize=8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('./HBV_IT_miRNA_concordance.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Figure saved: HBV_IT_miRNA_concordance.png')"
